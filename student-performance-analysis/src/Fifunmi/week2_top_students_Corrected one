import pandas as pd

def get_top_scores(df, subject_column, num_top=5):
    """
    Finds the top-performing students in a given subject.
    """
    # Hint 1: Convert column data into a list.
    scores_list = df[subject_column].tolist()
    
    # Sorting the list (Using the reverse=True sorts from highest to lowest)
    scores_list.sort(reverse=True)
    
    # Return only the highest values.
    return scores_list[:num_top]

# --- Testing the Function ---
# Load the dataset
df = pd.read_csv('StudentsPerformance (1).csv')

# Getting  the top 10 math scores
top_10_math = get_top_scores(df, 'math score', num_top=10)
print(f"Top 10 Math Scores: {top_10_math}")
